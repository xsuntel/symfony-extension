{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "autoUpdatesChannel": "stable",
  "cleanupPeriodDays": 30,
  "defaultShell": "bash",
  "effortLevel": "high",
  "outputStyle": "english-output-style",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32768",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0",
    "MAX_MCP_OUTPUT_TOKENS": "25000",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "STATUSLINE_CHECK_UPDATES": "true",
    "EDITOR": "code --wait"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pw-play /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null || aplay /usr/share/sounds/alsa/Front_Center.wav 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/scripts/statusline.sh",
    "padding": 0
  },
  "permissions": {
    "defaultMode": "plan",
    "ask": ["Bash(git push:*)"],
    "allow": [
      "Edit(.claude/tmp/**/*)",
      "Edit(app/tsconfig.json)",
      "Edit(app/src/**/*)",
      "Edit(app/assets/**/*)",
      "Edit(app/package.json)",
      "Edit(app/eslint.config.mjs)",
      "Edit(app/.vscode-test.mjs)",
      "Edit(diagram/**/*)",
      "Edit(scripts/**/*)",
      "Edit(tools/**/*)",
      "Bash(git:*)",
      "Bash(cd:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:symfony.com)",
      "WebFetch(domain:ux.symfony.com)",
      "WebFetch(domain:stimulus.hotwired.dev)"
    ],

    "deny": [
      "Edit(app/secrets/**/*)",
      "Read(app/secrets/**/*)",
      "Edit(app/.env)",
      "Read(app/.env)",
      "Edit(app/.env.*)",
      "Read(app/.env.*)",
      "Edit(.env.*)",
      "Read(.env.*)",
      "Edit(.gitignore)",
      "Edit(app/config/jwt/**/*)",
      "Read(app/config/jwt/**/*)",
      "Edit(app/config/secrets/**/*)",
      "Read(app/config/secrets/**/*)",
      "Edit(app/auth.json)",
      "Read(app/auth.json)",
      "Read(.mcp.json)",
      "Edit(.mcp.json)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/*.csr)",
      "Read(**/*.der)",
      "Read(**/*.jks)",
      "Read(**/*.p7*)",
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(passwd:*)"
    ]
  },
  "includeCoAuthoredBy": false,
  "theme": "dark"
}
